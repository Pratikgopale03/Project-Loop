# Project LOOP Environment Variables Template

# 1. Database Connection URL
# If you are using Supabase or Neon (free tier), use the connection string provided by them.
# It should look like: postgresql://[user]:[password]@[host]:[port]/[db_name]?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/project_loop?schema=public"

# 2. NextAuth Configurations
# Run this command in your terminal to generate a secure random secret key:
# openssl rand -base64 32
# Paste the generated key below.
NEXTAUTH_SECRET="your-super-secret-nextauth-key-change-me"

# The base URL of your application (use http://localhost:3000 for local development)
NEXTAUTH_URL="http://localhost:3000"

# 3. Anthropic Claude API Key (Required for Phase 3 AI features)
# Get a key from the Anthropic Console: https://console.anthropic.com/
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
